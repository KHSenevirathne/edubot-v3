# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
venv/
env/
.venv/
.env
.env.*
!.env.example

# Build artefacts
build/
dist/
*.spec.bak

# Logs / runtime junk
*.log
logs/
*.tmp

# IDE / OS noise
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Secrets - never commit
secrets.json
*.pem
*.key

# Live SQLite database. The bot WRITES to this file at runtime
# (chat_history, feedback, learned_patterns), so tracking it in git
# means every redeploy fights with whatever the production process
# has been logging. Instead, app.py auto-runs seed_db.py the first
# time it boots against an empty database (`courses` table empty).
data/edubot.db
data/edubot.db-journal
data/edubot.db-shm
data/edubot.db-wal

# Trained model artefacts - generated by train.py on first deploy.
# Excluded from git so live retraining on the server (PythonAnywhere)
# is never overwritten by a git pull.
models/*.pkl
models/model_info.txt
